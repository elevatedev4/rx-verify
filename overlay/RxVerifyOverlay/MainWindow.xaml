<Window x:Class="RxVerifyOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RxVerifyOverlay.Models"
        Title="Rx Verify"
        Width="420" Height="560"
        MinWidth="340" MinHeight="300"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1E1E1E">
    <!--
        Always-on-top (Topmost="True" — a hard requirement: the
        pharmacist needs this visible over PioneerRx at all times), and
        freely movable/resizable like any normal window (drag the title
        bar, drag the resize grip) so Will can park it wherever fits his
        monitor layout. Left/Top are just an initial position, not a
        pin — WPF remembers wherever the user drags it for the rest of
        that run; persisting position across launches is a nice-to-have,
        not done in v0 (see README "Deferred").
    -->
    <Window.Resources>
        <SolidColorBrush x:Key="GreenBrush" Color="#FF2E7D32" />
        <SolidColorBrush x:Key="YellowBrush" Color="#FFF9A825" />
        <SolidColorBrush x:Key="RedBrush" Color="#FFC62828" />
        <SolidColorBrush x:Key="NeutralBrush" Color="#FF3A3A3A" />

        <Style x:Key="PillTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title / summary counts -->
            <RowDefinition Height="Auto" /> <!-- Status message -->
            <RowDefinition Height="Auto" /> <!-- Toolbar buttons -->
            <RowDefinition Height="*" />    <!-- Verdict list (fixed order, never resorted) -->
            <RowDefinition Height="Auto" /> <!-- Settings (collapsible-ish, just always shown small in v0) -->
        </Grid.RowDefinitions>

        <!-- Row 0: title + green/yellow/red summary pills -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Rx Verify" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="{StaticResource GreenBrush}" CornerRadius="4" Padding="8,3" Margin="2,0">
                    <TextBlock Style="{StaticResource PillTextStyle}" Text="{Binding GreenCount, StringFormat=✓ {0}}" />
                </Border>
                <Border Background="{StaticResource YellowBrush}" CornerRadius="4" Padding="8,3" Margin="2,0">
                    <TextBlock Style="{StaticResource PillTextStyle}" Text="{Binding YellowCount, StringFormat=? {0}}" />
                </Border>
                <Border Background="{StaticResource RedBrush}" CornerRadius="4" Padding="8,3" Margin="2,0">
                    <TextBlock Style="{StaticResource PillTextStyle}" Text="{Binding RedCount, StringFormat=✗ {0}}" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Row 1: status line -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#FFBBBBBB" FontSize="11"
                   TextWrapping="Wrap" Margin="0,0,0,8" />

        <!-- Row 2: toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Refresh" Padding="10,4" Margin="0,0,6,0" Click="OnRefreshClick" />
            <Button Content="Dump UIA Tree..." Padding="10,4" Margin="0,0,6,0" Click="OnDumpTreeClick" />
            <CheckBox x:Name="AutoRefreshCheckBox" Content="Auto (5s)" Foreground="White" VerticalAlignment="Center"
                      Checked="OnAutoRefreshToggled" Unchecked="OnAutoRefreshToggled" />
        </StackPanel>

        <!--
            Row 3: verdict rows, in FIXED PHARMACIST ORDER — Patient,
            Patient DOB, Patient Address, Prescriber, Date Written, Drug,
            Sig, Quantity, Days Supply, Refills. This ItemsControl binds
            directly to OverlayViewModel.Verdicts, which is populated in
            FIELD_ORDER by OverlayViewModel.RefreshAsync() and is NEVER
            sorted here or anywhere else — see FieldOrder.Fields (hard
            requirement from the owner, a pharmacist: rows must mirror
            the data-entry screen's order and never jump around based on
            severity).
        -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Verdicts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource NeutralBrush}" CornerRadius="4" Margin="0,0,0,6" Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" VerticalAlignment="Top" Margin="0,0,8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource YellowBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Green}">
                                                    <Setter Property="Background" Value="{StaticResource GreenBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                    <Setter Property="Background" Value="{StaticResource RedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Glyph}" Style="{StaticResource PillTextStyle}" />
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Foreground="#FFDDDDDD" FontSize="11" TextWrapping="Wrap">
                                        <Run Text="Source: " FontWeight="SemiBold" /><Run Text="{Binding SourceValue}" />
                                    </TextBlock>
                                    <TextBlock Foreground="#FFDDDDDD" FontSize="11" TextWrapping="Wrap">
                                        <Run Text="Entered: " FontWeight="SemiBold" /><Run Text="{Binding EnteredValue}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Explanation}" Foreground="#FFAAAAAA" FontSize="10"
                                               FontStyle="Italic" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 4: engine path settings, always visible in v0 (small footprint, no PHI) -->
        <Expander Grid.Row="4" Header="Engine settings" Foreground="White" Margin="0,8,0,0">
            <StackPanel Margin="0,6,0,0">
                <TextBlock Text="rx-verify dist/cli.js path:" Foreground="#FFBBBBBB" FontSize="11" />
                <Grid Margin="0,2,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CliPathTextBox" Grid.Column="0" Padding="4" />
                    <Button Grid.Column="1" Content="Browse..." Margin="4,0,0,0" Padding="8,4" Click="OnBrowseCliPathClick" />
                </Grid>

                <TextBlock Text="Node executable (usually just 'node'):" Foreground="#FFBBBBBB" FontSize="11" />
                <TextBox x:Name="NodeExeTextBox" Padding="4" Margin="0,2,0,6" />

                <Button Content="Save settings" Padding="8,4" HorizontalAlignment="Left" Click="OnSaveSettingsClick" />
            </StackPanel>
        </Expander>
    </Grid>
</Window>
