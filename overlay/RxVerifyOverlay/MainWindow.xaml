<Window x:Class="RxVerifyOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RxVerifyOverlay.Models"
        Title="VerifyOCR"
        Width="420" Height="720"
        MinWidth="340" MinHeight="300"
        Topmost="True"
        WindowStartupLocation="Manual"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1E1E1E">
    <!--
        Always-on-top (Topmost="True" — a hard requirement: the
        pharmacist needs this visible over PioneerRx at all times), and
        freely movable/resizable like any normal window (drag the title
        bar, drag the resize grip) so Will can park it wherever fits his
        monitor layout. Left/Top are just an initial position, not a
        pin — WPF remembers wherever the user drags it for the rest of
        that run; persisting position across launches is a nice-to-have,
        not done in v0 (see README "Deferred").

        W-T11 item 4: Left is deliberately NOT set here (was a fixed
        Left="20", i.e. hugging the LEFT edge) — it's computed in
        MainWindow.xaml.cs's constructor from the primary screen's
        working-area width so the window launches near the RIGHT edge
        instead, since Left="20" here would just be overwritten before
        the window is shown anyway.

        W-T13 item 2: Top is likewise deliberately NOT set here (was a
        fixed Top="20", i.e. hugging the very top of the screen) — it's
        now computed in MainWindow.xaml.cs's constructor as ~200px down
        from the work area's top, clamped on-screen the same way Left
        is, so the window no longer launches crammed against the top
        edge.
    -->
    <Window.Resources>
        <SolidColorBrush x:Key="GreenBrush" Color="#FF2E7D32" />
        <SolidColorBrush x:Key="YellowBrush" Color="#FFF9A825" />
        <SolidColorBrush x:Key="RedBrush" Color="#FFC62828" />
        <SolidColorBrush x:Key="NeutralBrush" Color="#FF3A3A3A" />
        <!-- GrayBrush: category box/header when there's NO DATA at all
             (HasData=false), distinct from GreenBrush so "no data" never
             reads as "everything matches" (see CategoryViewModel.HasData). -->
        <SolidColorBrush x:Key="GrayBrush" Color="#FF555555" />

        <!-- Muted/dark variants of the same hues for the WHOLE category
             box background (not just the header strip); full-strength
             GreenBrush/YellowBrush/RedBrush across an entire card would
             wash out the white row text, so the box uses a darker tint of
             the same color while the header keeps the bold version. -->
        <SolidColorBrush x:Key="BoxGreenBrush" Color="#FF1B3A1E" />
        <SolidColorBrush x:Key="BoxYellowBrush" Color="#FF4A3B12" />
        <SolidColorBrush x:Key="BoxRedBrush" Color="#FF4A1F1F" />
        <SolidColorBrush x:Key="BoxGrayBrush" Color="#FF2A2A2A" />

        <!--
            W-T9 item 3: buttons were "too bright" (default WPF chrome is
            light gray/white), which draws the eye away from the verdict
            list — the actual point of the overlay. This implicit Style
            (no x:Key, so it applies to EVERY Button in the window,
            toolbar and Settings expander alike) recolors them close to
            the window's own #FF1E1E1E background: a subtle dark gray
            fill with a slightly lighter border for definition and
            legible (but low-contrast, non-attention-grabbing) light-gray
            text. Hover/pressed states get a small step up in brightness
            so the button still visibly responds to interaction without
            being bright at rest.
        -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="Foreground" Value="#FFCCCCCC" />
            <Setter Property="BorderBrush" Value="#FF3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF353535" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF404040" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title -->
            <RowDefinition Height="Auto" /> <!-- Verification method toggle (OCR default / Escript tab direct read) -->
            <RowDefinition Height="*" />    <!-- Verdict list (fixed order, never resorted) — the main content -->
            <RowDefinition Height="Auto" /> <!-- W-T11 item 6: e-script notes, red text, only when present -->
            <RowDefinition Height="Auto" /> <!-- VerifyOCR: OCR status line + raw-text expander -->
            <RowDefinition Height="Auto" /> <!-- Bottom bar: status message + Refresh/Dump/Auto-watch controls -->
            <RowDefinition Height="Auto" /> <!-- Settings (collapsible-ish, just always shown small in v0) -->
        </Grid.RowDefinitions>

        <!--
            Row 0: title + a small "VerifyOCR" badge so it's obvious which
            build is running when this and the main Rx Verify overlay are
            open side by side (this branch deliberately keeps the window
            Title itself as the only OTHER identity marker — see
            RxVerifyOverlay.csproj header for why namespace/assembly stay
            unchanged). The green/yellow/red summary count pills that used
            to live here were removed per Will's W-T9 item 2 feedback (not
            needed — the per-category header rollups below already convey
            this).
        -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
            <TextBlock Text="Rx Verify" Foreground="White" FontSize="16" FontWeight="Bold" />
            <Border Background="#FF2E7D32" CornerRadius="3" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="MethodBadgeText" Text="OCR" Foreground="White" FontSize="10" FontWeight="Bold" />
            </Border>
        </StackPanel>

        <!--
            Row 1: runtime source-method toggle (main task: combine
            "Verify" (UIA/Escript-tab read) and "VerifyOCR" (screen-OCR
            read) into one app where the pharmacist picks at runtime).
            OCR stays the default (see Models/OverlaySettings.cs
            VerificationMethod). Switching immediately saves settings and
            triggers a fresh RefreshAsync (see OnMethodChanged in
            MainWindow.xaml.cs) so the change takes effect right away
            instead of waiting for the next auto-watch tick. The active
            method is also reflected in the badge above (MethodBadgeText).
        -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Source:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0" />
            <RadioButton x:Name="MethodOcrRadioButton" GroupName="VerificationMethod" Content="OCR (default)"
                         Foreground="#FFCCCCCC" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"
                         IsChecked="True" Checked="OnMethodChanged" />
            <RadioButton x:Name="MethodUiaRadioButton" GroupName="VerificationMethod" Content="Escript tab (direct read)"
                         Foreground="#FFCCCCCC" FontSize="10" VerticalAlignment="Center" Checked="OnMethodChanged" />
        </StackPanel>

        <!--
            Row 2: compact grouped table — 3 categories (Patient /
            Prescriber / Rx, see Models/EngineModels.cs
            FieldCategories), each with a rolled-up status header
            (worst-status-wins: any Red field -> Red header, else any
            Yellow -> Yellow, else Green) and its field rows below in
            small print, FIXED PHARMACIST FIELD ORDER within the category
            (never re-sorted — hard requirement: rows must mirror the
            data-entry screen's order, never jump around by severity).
            Binds directly to OverlayViewModel.Categories (built/rolled-up
            every refresh in OverlayViewModel.RefreshAsync), which is
            already in FieldCategories.Order — Patient, Prescriber, Rx
            (sig now lives inline at the bottom of Rx, along with drug,
            since both are inherently fuzzy matches — see
            FieldCategories.CategoryByField doc). Reason code +
            explanation are NOT always-visible text (that's what made the
            old per-field-card layout tall) — they're a hover tooltip on
            the row instead (VerdictRowViewModel.TooltipText), so the
            whole table stays small enough to see all fields at once for
            a normal Rx without scrolling. This is now the main content,
            given the full remaining vertical space (Height="*") — the
            toolbar/status controls that used to live above it moved to
            the bottom bar below (W-T9 item 1).
        -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Column header labels for the compact table below -->
            <Grid Grid.Row="0" Margin="4,0,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62" />
                    <ColumnDefinition Width="*" MinWidth="70" />
                    <ColumnDefinition Width="*" MinWidth="70" />
                    <ColumnDefinition Width="14" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Field" Foreground="#FF888888" FontSize="9" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="Source" Foreground="#FF888888" FontSize="9" FontWeight="Bold" Margin="4,0,0,0" />
                <TextBlock Grid.Column="2" Text="Entered" Foreground="#FF888888" FontSize="9" FontWeight="Bold" Margin="4,0,0,0" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Box background is a FIXED neutral (no longer
                                tinted by the category's rolled-up status —
                                per Will's rework request, that signal now
                                lives on each individual field row below AND
                                as the header's status text (see
                                CategoryViewModel.StatusText), not on the box
                                itself; a box-wide color plus a per-row color
                                plus a header-strip color was one coloring
                                layer too many).
                            -->
                            <Border Background="{StaticResource BoxGrayBrush}" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="4" Margin="0,0,0,4">
                                <StackPanel>
                                    <!--
                                        Category header (W-T11 item 1: REWORKED back to a
                                        plain, quiet heading — this REVERSES the earlier
                                        W-T9 item 4 styling above; W-T13 item 1: re-tuned
                                        from muted-gray-on-gray to bold-white-on-window-bg).
                                        The rolled-up status glyph and "— <StatusText>"
                                        label (e.g. "Match" / "Partial match" / "Verify")
                                        are gone entirely — per Will's feedback, the header
                                        was drawing the eye when the field ROWS below (which
                                        already carry the same green/yellow/red whole-row
                                        coloring, see the Rows ItemsControl below) are the
                                        thing that should be looked at. The header row's
                                        Background is set to the window's own #FF1E1E1E
                                        (not the card's BoxGrayBrush behind it) so it forms
                                        no distinct band/tint of its own — it visually
                                        punches through the card into the window background
                                        — while the text is bold WHITE so the category name
                                        still reads clearly at a glance.
                                        CategoryViewModel.Glyph/StatusText/HeaderStatusText
                                        still exist in code (still covered by
                                        Tests/CategoryStatusTextTests.cs) — they're simply no
                                        longer bound anywhere in this template.
                                    -->
                                    <Border Background="#FF1E1E1E">
                                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFFFF" FontWeight="Bold" FontSize="11" Margin="5,3,0,2" />
                                    </Border>

                                    <!--
                                        Field rows: status icon | Field | Source | Entered, with
                                        the WHOLE ROW colored uniformly by that row's own match
                                        status (green/yellow/red) — reworked per Will's live-test
                                        feedback, replacing the old scheme where the Source cell
                                        stayed neutral and only the Entered cell was tinted
                                        (Twinlist-style split). One color across the whole row
                                        reads faster at a glance than tracking which of two cells
                                        is colored. The leading glyph remains the WCAG-required
                                        non-color-only signal.
                                    -->
                                    <ItemsControl ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="3" Margin="0,1.5" Padding="4,1.5" ToolTipService.ToolTip="{Binding TooltipText}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BoxGreenBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Yellow}">
                                                                    <Setter Property="Background" Value="{StaticResource BoxYellowBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                                    <Setter Property="Background" Value="{StaticResource BoxRedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="50" />
                                                            <ColumnDefinition Width="*" MinWidth="70" />
                                                            <ColumnDefinition Width="*" MinWidth="70" />
                                                        </Grid.ColumnDefinitions>

                                                        <!--
                                                            Column 0: leading status glyph (WCAG: icon is the
                                                            PRIMARY signal, color reinforces). "✓" / "!" / "✗" —
                                                            never a color-only dot.

                                                            PENDING (drug row only, while its background
                                                            lookup is still running — see
                                                            VerdictRowViewModel.IsPending and
                                                            OverlayViewModel.RefreshAsync's two-phase
                                                            refresh): swap the glyph for a small
                                                            indeterminate spinner instead of the yellow "!" —
                                                            a "needs a look" glyph would misleadingly imply a
                                                            real verdict was already reached.
                                                        -->
                                                        <Grid Grid.Column="0">
                                                            <TextBlock Text="{Binding Glyph}" FontWeight="Bold" FontSize="12" TextAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Yellow}">
                                                                                <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                                                <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <ProgressBar IsIndeterminate="True" Width="12" Height="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <ProgressBar.Style>
                                                                    <Style TargetType="ProgressBar">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ProgressBar.Style>
                                                            </ProgressBar>
                                                        </Grid>

                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#FFBBBBBB" FontSize="10" TextWrapping="Wrap" VerticalAlignment="Center" />

                                                        <!--
                                                            Column 2: Source value — plain text, no per-cell
                                                            background; the row's own Border (above) is what
                                                            now carries the match-state color, uniformly
                                                            across both Source and Entered.
                                                        -->
                                                        <TextBlock Grid.Column="2" Text="{Binding SourceValue}" Foreground="White" FontSize="10" TextWrapping="Wrap" Margin="1,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTabularField}" Value="True">
                                                                            <Setter Property="FontFamily" Value="Consolas" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!--
                                                            Column 3: Entered value — plain text, same
                                                            uniform-row-color treatment as Source above.
                                                            Mismatches (red) still render the entered text
                                                            BOLD so a real discrepancy visually pops more
                                                            than a match recedes. Tabular/digit fields (NPI,
                                                            phone, quantity, refills) use a monospace font so
                                                            a transposed digit is visible as column
                                                            misalignment, not just a string diff.
                                                        -->
                                                        <TextBlock Grid.Column="3" Text="{Binding EnteredValue}" Foreground="White" FontSize="10" TextWrapping="Wrap" Margin="1,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontWeight" Value="Normal" />
                                                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                                            <Setter Property="FontWeight" Value="Bold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsTabularField}" Value="True">
                                                                            <Setter Property="FontFamily" Value="Consolas" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!--
            Row 2 (W-T11 item 6): e-script notes (NCPDP Note element, see
            Parsing/EscriptTreeParser.ParseNotes and
            OverlayViewModel.Notes/HasNotes) — RED text, at the BOTTOM of
            the overlay (below the verdict table, above the bottom
            controls bar), and only rendered at all when at least one
            note was found. Collapsed via HasNotes so an Rx with no notes
            (the common case) shows nothing here at all — no empty red
            box.
        -->
        <Border Grid.Row="3" Margin="0,4,0,0" Padding="0,0,0,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasNotes}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ItemsControl ItemsSource="{Binding Notes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#FFEF5350" FontSize="10" FontWeight="Bold"
                                   TextWrapping="Wrap" Margin="0,1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!--
            Row 3 (VerifyOCR): always-visible OCR timing/char-count status
            line (branch brief item 3 — the headline diagnostic: proving
            capture+OCR speed and letting Will judge text quality on his
            real screen) plus a collapsed-by-default expander showing the
            full raw OCR text from the last read. Ocr/OcrLogger.cs writes
            the same numbers + full text to %TEMP%\VerifyOCR\ocr-*.log on
            every read, for a permanent record — this is the live/
            in-the-moment view of the same data.
        -->
        <StackPanel Grid.Row="4" Margin="0,0,0,4">
            <TextBlock Text="{Binding OcrStatusText}" Foreground="#FF9CCC65" FontSize="10" TextWrapping="Wrap" />
            <Expander Header="Raw OCR text (last read)" Foreground="#FFBBBBBB" FontSize="10" Margin="0,2,0,0">
                <TextBox Text="{Binding LastOcrRawText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                         AcceptsReturn="True" MaxHeight="150" VerticalScrollBarVisibility="Auto"
                         Background="#FF141414" Foreground="#FFDDDDDD" FontFamily="Consolas" FontSize="10"
                         BorderBrush="#FF3A3A3A" Margin="0,2,0,0" Padding="4" />
            </Expander>
        </StackPanel>

        <!--
            Row 4: BOTTOM BAR (W-T9 item 1) — Refresh, "Dump UIA Tree",
            the Auto-watch checkbox, and the "last checked"/status text
            all moved down here from the old top toolbar, so the verdict
            list above gets the space and the pharmacist's eye starts on
            data, not controls. Status message (which includes "Last
            checked h:mm:ss" — see OverlayViewModel.RefreshAsync/
            RefreshDrugFieldAsync) sits above the button row, both inside
            one bottom-anchored block.
        -->
        <Border Grid.Row="5" BorderBrush="#FF2A2A2A" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,4,0,0">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#FFBBBBBB" FontSize="10"
                           TextWrapping="Wrap" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Refresh" Margin="0,0,6,0" Click="OnRefreshClick" />
                    <!--
                        "Copy logs" — one-click clipboard copy of everything
                        needed to debug the CURRENTLY-DISPLAYED Rx (raw OCR
                        text + word geometry, parsed/mapped fields, match
                        verdicts, warnings/errors, app version + commit) so
                        Will can paste it straight into a message instead of
                        digging through %TEMP%\VerifyOCR\ocr-*.log. See
                        OverlayViewModel.BuildCurrentLogBlob /
                        Diagnostics/RxLogFormatter.cs. In-memory + clipboard
                        only — reflects only this Rx, nothing persisted or
                        accumulated across scripts.
                    -->
                    <Button Content="Copy logs" Margin="0,0,6,0" Click="OnCopyLogsClick" />
                    <!--
                        "Copy logs (no HIPAA)" — same clipboard blob as
                        "Copy logs", but with all patient identifiers
                        (name, DOB, address — title, verdict rows, raw OCR
                        text + word list) redacted, so a REAL prescription's
                        log can be pasted for debugging without exposing
                        PHI. Prescriber/drug/sig/qty/refills/dates and the
                        OCR geometry are preserved. See
                        OverlayViewModel.BuildCurrentLogBlob(redactPatient:
                        true) / Diagnostics/RxLogFormatter.cs.
                    -->
                    <Button Content="Copy logs (no HIPAA)" Margin="0,0,6,0" Click="OnCopyLogsNoHipaaClick" />
                    <Button Content="Dump UIA Tree..." Margin="0,0,6,0" Click="OnDumpTreeClick" />
                    <!--
                        W-T11 item 3: DEFAULT ON — checked by construction
                        (IsChecked="True") so watching begins automatically
                        at launch instead of requiring a manual click every
                        session. See MainWindow.xaml.cs constructor for how
                        the timer is actually started to match this initial
                        state (Checked doesn't reliably fire off of the XAML
                        default before the timer field exists).
                    -->
                    <CheckBox x:Name="AutoRefreshCheckBox" Content="Auto-watch" Foreground="#FFCCCCCC" VerticalAlignment="Center"
                              IsChecked="True" Checked="OnAutoRefreshToggled" Unchecked="OnAutoRefreshToggled" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 5: engine path settings, always visible in v0 (small footprint, no PHI) -->
        <Expander Grid.Row="6" Header="Engine settings" Foreground="White" Margin="0,4,0,0">
            <StackPanel Margin="0,6,0,0">
                <TextBlock Text="rx-verify dist/cli.js path:" Foreground="#FFBBBBBB" FontSize="11" />
                <Grid Margin="0,2,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CliPathTextBox" Grid.Column="0" Padding="4" />
                    <Button Grid.Column="1" Content="Browse..." Margin="4,0,0,0" Click="OnBrowseCliPathClick" />
                </Grid>

                <TextBlock Text="Node executable (usually just 'node'):" Foreground="#FFBBBBBB" FontSize="11" />
                <TextBox x:Name="NodeExeTextBox" Padding="4" Margin="0,2,0,6" />

                <!--
                    VerifyOCR capture-region override (see
                    Models/OverlaySettings.cs and
                    Ocr/EscriptImageCapture.cs ResolveCaptureRegion).
                    Default (unchecked) auto-detects the center Escript
                    pane's on-screen bounds — this section only matters if
                    that auto-detection doesn't land on the right part of
                    Will's screen.
                -->
                <TextBlock Text="OCR capture region (advanced — leave unchecked to auto-detect the Escript pane):"
                           Foreground="#FFBBBBBB" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
                <CheckBox x:Name="UseExplicitCaptureRegionCheckBox" Content="Use explicit region below" Foreground="#FFCCCCCC" Margin="0,2,0,4" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,3,0">
                        <TextBlock Text="Left" Foreground="#FF888888" FontSize="9" />
                        <TextBox x:Name="CaptureRegionLeftTextBox" Padding="4" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="3,0,3,0">
                        <TextBlock Text="Top" Foreground="#FF888888" FontSize="9" />
                        <TextBox x:Name="CaptureRegionTopTextBox" Padding="4" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="3,0,3,0">
                        <TextBlock Text="Width" Foreground="#FF888888" FontSize="9" />
                        <TextBox x:Name="CaptureRegionWidthTextBox" Padding="4" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="3,0,0,0">
                        <TextBlock Text="Height" Foreground="#FF888888" FontSize="9" />
                        <TextBox x:Name="CaptureRegionHeightTextBox" Padding="4" />
                    </StackPanel>
                </Grid>

                <Button Content="Save settings" HorizontalAlignment="Left" Click="OnSaveSettingsClick" />
            </StackPanel>
        </Expander>
    </Grid>
</Window>
