<Window x:Class="RxVerifyOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RxVerifyOverlay.Models"
        Title="Rx Verify"
        Width="420" Height="620"
        MinWidth="340" MinHeight="300"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1E1E1E">
    <!--
        Always-on-top (Topmost="True" — a hard requirement: the
        pharmacist needs this visible over PioneerRx at all times), and
        freely movable/resizable like any normal window (drag the title
        bar, drag the resize grip) so Will can park it wherever fits his
        monitor layout. Left/Top are just an initial position, not a
        pin — WPF remembers wherever the user drags it for the rest of
        that run; persisting position across launches is a nice-to-have,
        not done in v0 (see README "Deferred").
    -->
    <Window.Resources>
        <SolidColorBrush x:Key="GreenBrush" Color="#FF2E7D32" />
        <SolidColorBrush x:Key="YellowBrush" Color="#FFF9A825" />
        <SolidColorBrush x:Key="RedBrush" Color="#FFC62828" />
        <SolidColorBrush x:Key="NeutralBrush" Color="#FF3A3A3A" />
        <!-- GrayBrush: category box/header when there's NO DATA at all
             (HasData=false), distinct from GreenBrush so "no data" never
             reads as "everything matches" (see CategoryViewModel.HasData). -->
        <SolidColorBrush x:Key="GrayBrush" Color="#FF555555" />

        <!-- Muted/dark variants of the same hues for the WHOLE category
             box background (not just the header strip); full-strength
             GreenBrush/YellowBrush/RedBrush across an entire card would
             wash out the white row text, so the box uses a darker tint of
             the same color while the header keeps the bold version. -->
        <SolidColorBrush x:Key="BoxGreenBrush" Color="#FF1B3A1E" />
        <SolidColorBrush x:Key="BoxYellowBrush" Color="#FF4A3B12" />
        <SolidColorBrush x:Key="BoxRedBrush" Color="#FF4A1F1F" />
        <SolidColorBrush x:Key="BoxGrayBrush" Color="#FF2A2A2A" />

        <!--
            W-T9 item 3: buttons were "too bright" (default WPF chrome is
            light gray/white), which draws the eye away from the verdict
            list — the actual point of the overlay. This implicit Style
            (no x:Key, so it applies to EVERY Button in the window,
            toolbar and Settings expander alike) recolors them close to
            the window's own #FF1E1E1E background: a subtle dark gray
            fill with a slightly lighter border for definition and
            legible (but low-contrast, non-attention-grabbing) light-gray
            text. Hover/pressed states get a small step up in brightness
            so the button still visibly responds to interaction without
            being bright at rest.
        -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="Foreground" Value="#FFCCCCCC" />
            <Setter Property="BorderBrush" Value="#FF3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF353535" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF404040" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title -->
            <RowDefinition Height="*" />    <!-- Verdict list (fixed order, never resorted) — the main content -->
            <RowDefinition Height="Auto" /> <!-- Bottom bar: status message + Refresh/Dump/Auto-watch controls -->
            <RowDefinition Height="Auto" /> <!-- Settings (collapsible-ish, just always shown small in v0) -->
        </Grid.RowDefinitions>

        <!-- Row 0: title only. The green/yellow/red summary count pills that used to live here were removed per Will's W-T9 item 2 feedback (not needed — the per-category header rollups below already convey this). -->
        <TextBlock Grid.Row="0" Text="Rx Verify" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />

        <!--
            Row 1: compact grouped table — 4 categories (Patient /
            Prescriber / Rx / Sig, see Models/EngineModels.cs
            FieldCategories), each with a rolled-up status header
            (worst-status-wins: any Red field -> Red header, else any
            Yellow -> Yellow, else Green) and its field rows below in
            small print, FIXED PHARMACIST FIELD ORDER within the category
            (never re-sorted — hard requirement: rows must mirror the
            data-entry screen's order, never jump around by severity).
            Binds directly to OverlayViewModel.Categories (built/rolled-up
            every refresh in OverlayViewModel.RefreshAsync), which is
            already in FieldCategories.Order — Patient, Prescriber, Rx,
            then Sig LAST (W-T9 item 6: sig gets its own box, listed
            last, and is excluded from the Rx rollup since it lives in
            its own category with its own Rows/Status — see
            FieldCategories.CategoryByField doc). Reason code +
            explanation are NOT always-visible text (that's what made the
            old per-field-card layout tall) — they're a hover tooltip on
            the row instead (VerdictRowViewModel.TooltipText), so the
            whole table stays small enough to see all fields at once for
            a normal Rx without scrolling. This is now the main content,
            given the full remaining vertical space (Height="*") — the
            toolbar/status controls that used to live above it moved to
            the bottom bar below (W-T9 item 1).
        -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Column header labels for the compact table below -->
            <Grid Grid.Row="0" Margin="4,0,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62" />
                    <ColumnDefinition Width="*" MinWidth="70" />
                    <ColumnDefinition Width="*" MinWidth="70" />
                    <ColumnDefinition Width="14" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Field" Foreground="#FF888888" FontSize="9" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="Source" Foreground="#FF888888" FontSize="9" FontWeight="Bold" Margin="4,0,0,0" />
                <TextBlock Grid.Column="2" Text="Entered" Foreground="#FF888888" FontSize="9" FontWeight="Bold" Margin="4,0,0,0" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Box background is a FIXED neutral (no longer
                                tinted by the category's rolled-up status —
                                per Will's rework request, that signal now
                                lives on each individual field row below AND
                                as the header's status text (see
                                CategoryViewModel.StatusText), not on the box
                                itself; a box-wide color plus a per-row color
                                plus a header-strip color was one coloring
                                layer too many).
                            -->
                            <Border Background="{StaticResource BoxGrayBrush}" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="4" Margin="0,0,0,4">
                                <StackPanel>
                                    <!--
                                        Category header: rolled-up status glyph LEADS the row
                                        (matches the same WCAG convention as the field rows
                                        below, where the glyph is the FIRST visual element
                                        rather than a trailing indicator, so the worst-status-
                                        wins rollup for the whole category reads before
                                        anything else at a glance), followed immediately by
                                        the category name, then the status label text right
                                        NEXT TO the name (e.g. "Patient — Match") — per
                                        Will's W-T9 item 4 feedback, this must sit right next
                                        to the title (not pinned out to the box's right edge)
                                        and must NOT be italic (see
                                        CategoryViewModel.HeaderStatusText, which supplies the
                                        "— <StatusText>" text directly so no XAML
                                        StringFormat/MultiBinding gymnastics are needed here).
                                    -->
                                    <Border CornerRadius="3,3,0,0" Padding="5,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource GreenBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Yellow}">
                                                        <Setter Property="Background" Value="{StaticResource YellowBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                        <Setter Property="Background" Value="{StaticResource RedBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasData}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource GrayBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Glyph}" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" TextAlignment="Center" Width="18" />
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding HeaderStatusText}" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!--
                                        Field rows: status icon | Field | Source | Entered, with
                                        the WHOLE ROW colored uniformly by that row's own match
                                        status (green/yellow/red) — reworked per Will's live-test
                                        feedback, replacing the old scheme where the Source cell
                                        stayed neutral and only the Entered cell was tinted
                                        (Twinlist-style split). One color across the whole row
                                        reads faster at a glance than tracking which of two cells
                                        is colored. The leading glyph remains the WCAG-required
                                        non-color-only signal.
                                    -->
                                    <ItemsControl ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="3" Margin="0,1.5" Padding="4,1.5" ToolTipService.ToolTip="{Binding TooltipText}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BoxGreenBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Yellow}">
                                                                    <Setter Property="Background" Value="{StaticResource BoxYellowBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                                    <Setter Property="Background" Value="{StaticResource BoxRedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="50" />
                                                            <ColumnDefinition Width="*" MinWidth="70" />
                                                            <ColumnDefinition Width="*" MinWidth="70" />
                                                        </Grid.ColumnDefinitions>

                                                        <!--
                                                            Column 0: leading status glyph (WCAG: icon is the
                                                            PRIMARY signal, color reinforces). "✓" / "!" / "✗" —
                                                            never a color-only dot.

                                                            PENDING (drug row only, while its background
                                                            lookup is still running — see
                                                            VerdictRowViewModel.IsPending and
                                                            OverlayViewModel.RefreshAsync's two-phase
                                                            refresh): swap the glyph for a small
                                                            indeterminate spinner instead of the yellow "!" —
                                                            a "needs a look" glyph would misleadingly imply a
                                                            real verdict was already reached.
                                                        -->
                                                        <Grid Grid.Column="0">
                                                            <TextBlock Text="{Binding Glyph}" FontWeight="Bold" FontSize="12" TextAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Yellow}">
                                                                                <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                                                <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <ProgressBar IsIndeterminate="True" Width="12" Height="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <ProgressBar.Style>
                                                                    <Style TargetType="ProgressBar">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ProgressBar.Style>
                                                            </ProgressBar>
                                                        </Grid>

                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#FFBBBBBB" FontSize="10" TextWrapping="Wrap" VerticalAlignment="Center" />

                                                        <!--
                                                            Column 2: Source value — plain text, no per-cell
                                                            background; the row's own Border (above) is what
                                                            now carries the match-state color, uniformly
                                                            across both Source and Entered.
                                                        -->
                                                        <TextBlock Grid.Column="2" Text="{Binding SourceValue}" Foreground="White" FontSize="10" TextWrapping="Wrap" Margin="1,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTabularField}" Value="True">
                                                                            <Setter Property="FontFamily" Value="Consolas" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!--
                                                            Column 3: Entered value — plain text, same
                                                            uniform-row-color treatment as Source above.
                                                            Mismatches (red) still render the entered text
                                                            BOLD so a real discrepancy visually pops more
                                                            than a match recedes. Tabular/digit fields (NPI,
                                                            phone, quantity, refills) use a monospace font so
                                                            a transposed digit is visible as column
                                                            misalignment, not just a string diff.
                                                        -->
                                                        <TextBlock Grid.Column="3" Text="{Binding EnteredValue}" Foreground="White" FontSize="10" TextWrapping="Wrap" Margin="1,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontWeight" Value="Normal" />
                                                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:VerdictStatus.Red}">
                                                                            <Setter Property="FontWeight" Value="Bold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsTabularField}" Value="True">
                                                                            <Setter Property="FontFamily" Value="Consolas" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!--
            Row 2: BOTTOM BAR (W-T9 item 1) — Refresh, "Dump UIA Tree",
            the Auto-watch checkbox, and the "last checked"/status text
            all moved down here from the old top toolbar, so the verdict
            list above gets the space and the pharmacist's eye starts on
            data, not controls. Status message (which includes "Last
            checked h:mm:ss" — see OverlayViewModel.RefreshAsync/
            RefreshDrugFieldAsync) sits above the button row, both inside
            one bottom-anchored block.
        -->
        <Border Grid.Row="2" BorderBrush="#FF2A2A2A" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,4,0,0">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#FFBBBBBB" FontSize="10"
                           TextWrapping="Wrap" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Refresh" Margin="0,0,6,0" Click="OnRefreshClick" />
                    <Button Content="Dump UIA Tree..." Margin="0,0,6,0" Click="OnDumpTreeClick" />
                    <CheckBox x:Name="AutoRefreshCheckBox" Content="Auto-watch" Foreground="#FFCCCCCC" VerticalAlignment="Center"
                              Checked="OnAutoRefreshToggled" Unchecked="OnAutoRefreshToggled" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 3: engine path settings, always visible in v0 (small footprint, no PHI) -->
        <Expander Grid.Row="3" Header="Engine settings" Foreground="White" Margin="0,4,0,0">
            <StackPanel Margin="0,6,0,0">
                <TextBlock Text="rx-verify dist/cli.js path:" Foreground="#FFBBBBBB" FontSize="11" />
                <Grid Margin="0,2,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CliPathTextBox" Grid.Column="0" Padding="4" />
                    <Button Grid.Column="1" Content="Browse..." Margin="4,0,0,0" Click="OnBrowseCliPathClick" />
                </Grid>

                <TextBlock Text="Node executable (usually just 'node'):" Foreground="#FFBBBBBB" FontSize="11" />
                <TextBox x:Name="NodeExeTextBox" Padding="4" Margin="0,2,0,6" />

                <Button Content="Save settings" HorizontalAlignment="Left" Click="OnSaveSettingsClick" />
            </StackPanel>
        </Expander>
    </Grid>
</Window>
